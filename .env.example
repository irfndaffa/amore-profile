# Password required to log into /admin
ADMIN_PASSWORD=

# Optional: secret used to sign the admin session cookie (falls back to ADMIN_PASSWORD if unset)
ADMIN_SESSION_SECRET=

# Vercel Blob read/write token. All editable site content (profile, stats,
# experience, skills, portfolio categories) plus every portfolio photo and
# video is stored in a private Vercel Blob store and served through
# src/app/api/portfolio-media/route.ts. Direct browser-to-storage uploads are
# also used for videos (Vercel Functions reject request bodies over 4.5MB, so
# videos can't be sent through a Server Action as base64).
# Create a Blob store under the project's Storage tab in the Vercel
# dashboard — this env var is added automatically once you do.
BLOB_READ_WRITE_TOKEN=

