# Password required to log into /admin
ADMIN_PASSWORD=

# Optional: secret used to sign the admin session cookie (falls back to ADMIN_PASSWORD if unset)
ADMIN_SESSION_SECRET=

# GitHub Personal Access Token with "repo" contents write access.
# Used by the admin panel to commit content/photo changes directly to this repo.
GITHUB_TOKEN=

# "owner/repo" of this project, e.g. irfndaffaa/amore-portfolio
GITHUB_REPO=

# Branch to commit admin changes to (defaults to "main")
GITHUB_BRANCH=main

# Vercel Blob read/write token, used for direct browser-to-storage video
# uploads in the admin panel (Vercel Functions reject request bodies over
# 4.5MB, so videos can't be sent through a Server Action as base64).
# Create a Blob store under the project's Storage tab in the Vercel
# dashboard — this env var is added automatically once you do.
BLOB_READ_WRITE_TOKEN=
